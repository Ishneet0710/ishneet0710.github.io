---

<Layout>
    <header class="masthead">
        <div class="masthead__inner">
            <a class="masthead__brand" href="#about">Ishneet Sukhvinder Singh</a>
            <div class="masthead__right">
                <ul class="masthead__nav">
                    {
                        navItems.map((item) => (
                            <li>
                                <a href={item.href} data-nav-section={item.section}>
                                    {item.title}
                                </a>
                            </li>
                        ))
                    }
                </ul>
                <button
                    id="theme-toggle"
                    class="theme-toggle"
                    type="button"
                    aria-label="Toggle color theme"
                >
                    <Icon name="sun" class="icon-sun" />
                    <Icon name="moon" class="icon-moon" />
                </button>
            </div>
        </div>
    </header>

    <div class="page-wrap">
        <aside class="sidebar">
            <div class="author__avatar">
                <Image
                    src={ishneetPP}
                    alt="Ishneet Sukhvinder Singh"
                    widths={[180, 360]}
                    sizes="180px"
                />
            </div>
            <div class="author__details">
                <h1 class="author__name">Ishneet Sukhvinder Singh</h1>
                <p class="author__bio">
                    Computer Engineering @ Oxford<br />Research @ UW RSE Lab
                </p>
            </div>
            <ul class="social-icons">
                {
                    socials.map((s) => (
                        <li>
                            <a href={s.url} target="_blank" rel="noopener noreferrer">
                                <Icon name={s.icon} />
                                <span>{s.label}</span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </aside>

        <main class="content">
            <section id="about" class="home-section">
                <p>
                    <span id="handwave">👋</span> Hi! I'm Ishneet, a Computer
                    Engineering student at <a
                        href="https://www.ox.ac.uk/"
                        target="_blank"
                        rel="noopener noreferrer">Oxford</a
                    >. I do research at the <a
                        href="https://rse-lab.cs.washington.edu/"
                        target="_blank"
                        rel="noopener noreferrer">UW RSE Lab</a
                    >, work on robotics at <strong>Menlo Research</strong>, and
                    am a National Science Scholar at <strong>A*STAR</strong>.
                </p>
                <p>
                    My research spans machine learning broadly — with a focus on
                    LLMs, retrieval, reinforcement learning, robotics, computer
                    vision, and interpretability.
                </p>
                <div class="interest-tags">
                    {interests.map((t) => <span class="tag">#{t}</span>)}
                </div>
            </section>

            <section id="news" class="home-section">
                <h2 class="home-section__title">🔥 News</h2>
                <ul
                    class="news-list is-collapsed"
                    id="news-list"
                    data-limit={NEWS_LIMIT}
                >
                    {
                        news.map((item, i) => (
                            <li class={i >= NEWS_LIMIT ? "is-hidden" : ""}>
                                <strong>[{item.date}]</strong>
                                <span set:html={item.html} />
                            </li>
                        ))
                    }
                </ul>
                {
                    news.length > NEWS_LIMIT && (
                        <button
                            class="news-toggle"
                            type="button"
                            data-news-toggle
                            aria-expanded="false"
                            aria-controls="news-list"
                        >
                            <span class="news-toggle__label">Show more</span>
                            <Icon name="chevron" />
                        </button>
                    )
                }
            </section>

            <section id="publications" class="home-section">
                <h2 class="home-section__title">📑 Publications</h2>
                <div class="publication-legend">
                    <span><code>*</code> equal contribution</span>
                </div>
                {publications.map((pub) => <PublicationCard {...pub} />)}
            </section>

            <section id="experience" class="home-section">
                <h2 class="home-section__title">💼 Experience</h2>
                <ul class="resume-section">
                    <li class="resume-entry">
                        <p class="resume-entry__heading">
                            <strong>University of Washington — RSE Lab</strong>
                        </p>
                        <p class="resume-entry__line">Research</p>
                    </li>
                    <li class="resume-entry">
                        <p class="resume-entry__heading">
                            <strong>Menlo Research</strong>
                        </p>
                        <p class="resume-entry__line">Robotics</p>
                    </li>
                </ul>
            </section>

            <section id="education" class="home-section">
                <h2 class="home-section__title">🎓 Education</h2>
                <ul class="resume-section">
                    <li class="resume-entry">
                        <p class="resume-entry__heading">
                            <strong>University of Oxford</strong>
                        </p>
                        <p class="resume-entry__line">
                            <em>Computer Engineering</em>
                        </p>
                    </li>
                </ul>
            </section>

            <section id="awards" class="home-section">
                <h2 class="home-section__title">🏅 Awards</h2>
                <ul class="award-list">
                    <li>National Science Scholarship (A*STAR)</li>
                </ul>
            </section>
        </main>
    </div>

    <script is:inline>
        // Theme toggle
        (function () {
            var btn = document.getElementById("theme-toggle");
            if (btn) {
                btn.addEventListener("click", function () {
                    var root = document.documentElement;
                    var next =
                        root.getAttribute("data-theme") === "dark"
                            ? "light"
                            : "dark";
                    root.setAttribute("data-theme", next);
                    try {
                        localStorage.setItem("theme", next);
                    } catch (e) {}
                });
            }
        })();

        // Collapsible news
        (function () {
            var toggle = document.querySelector("[data-news-toggle]");
            var list = document.getElementById("news-list");
            if (!toggle || !list) return;
            var label = toggle.querySelector(".news-toggle__label");
            toggle.addEventListener("click", function () {
                var collapsed = list.classList.toggle("is-collapsed");
                toggle.setAttribute("aria-expanded", String(!collapsed));
                if (label)
                    label.textContent = collapsed ? "Show more" : "Show less";
            });
        })();

        // Scrollspy — highlight the active nav section
        (function () {
            var links = Array.prototype.slice.call(
                document.querySelectorAll(".masthead__nav a[data-nav-section]")
            );
            if (!links.length || !("IntersectionObserver" in window)) return;
            var map = {};
            links.forEach(function (l) {
                map[l.getAttribute("data-nav-section")] = l;
            });
            var observer = new IntersectionObserver(
                function (entries) {
                    entries.forEach(function (entry) {
                        if (entry.isIntersecting) {
                            links.forEach(function (l) {
                                l.classList.remove("is-active");
                            });
                            var active = map[entry.target.id];
                            if (active) active.classList.add("is-active");
                        }
                    });
                },
                { rootMargin: "-45% 0px -50% 0px", threshold: 0 }
            );
            ["news", "publications", "experience", "education", "awards"].forEach(
                function (id) {
                    var el = document.getElementById(id);
                    if (el) observer.observe(el);
                }
            );
        })();
    </script>
</Layout>
