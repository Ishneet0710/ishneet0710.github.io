---
import "../styles/global.css";

const description =
    "Computer Engineering at Oxford. Research at UW RSE Lab. Robotics at Menlo Research. A*STAR National Science Scholar. Interests: ML, AI, LLMs, retrieval, RL, robotics, CV, interpretability.";
const ogImage = new URL("/ishneet.jpeg", Astro.site).href;
const year = 2026;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>Ishneet Sukhvinder Singh</title>
        <meta name="author" content="Ishneet Sukhvinder Singh" />
        <meta property="og:title" content="Ishneet Sukhvinder Singh" />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:url" content={Astro.site} />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content="Ishneet Sukhvinder Singh" />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        <link rel="icon" href="/favicon.ico" />
        <link
            rel="icon"
            type="image/png"
            href="/favicon_io/favicon-32x32.png"
            sizes="32x32"
        />
        <link
            rel="icon"
            type="image/png"
            href="/favicon_io/favicon-16x16.png"
            sizes="16x16"
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/favicon_io/apple-touch-icon.png"
        />
        <link rel="manifest" href="/favicon_io/site.webmanifest" />
        {/* Set theme before paint to avoid a flash of the wrong theme */}
        <script is:inline>
            (function () {
                try {
                    var stored = localStorage.getItem("theme");
                    var theme =
                        stored ||
                        (window.matchMedia("(prefers-color-scheme: dark)")
                            .matches
                            ? "dark"
                            : "light");
                    document.documentElement.setAttribute("data-theme", theme);
                } catch (e) {}
            })();
        </script>
    </head>
    <body>
        <slot />
        <footer class="site-footer">
            <div class="site-footer__inner">
                <span>© {year} Ishneet Sukhvinder Singh</span>
                <span>
                    Built with <a
                        href="https://astro.build"
                        target="_blank"
                        rel="noopener noreferrer">Astro</a
                    >
                </span>
            </div>
        </footer>
    </body>
</html>
