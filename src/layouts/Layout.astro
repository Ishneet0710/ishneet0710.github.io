---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta
            name="description"
            content="Computer Engineering student at Oxford. Research at UWash RSE Lab. Interests: ML, AI, LLMs, Retrieval, RL, Robotics, CV, Interpretability"
        />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Ishneet Sukhvinder Singh</title>
        <meta name="author" content="Ishneet Sukhvinder Singh" />
        <meta property="og:title" content="Ishneet Sukhvinder Singh" />
        <meta
            property="og:description"
            content="Computer Engineering student at Oxford. Research at UWash RSE Lab. Interests: ML, AI, LLMs, Retrieval, RL, Robotics, CV, Interpretability"
        />
        <meta property="og:image" content="/ishneet.jpeg" />
        <meta property="og:url" content="/" />
        <meta property="og:type" content="website" />
        <link rel="icon" href="/favicon.ico" />
        <link
            rel="icon"
            type="image/png"
            href="/favicon_io/favicon-32x32.png"
            sizes="32x32"
        />
        <link
            rel="icon"
            type="image/png"
            href="/favicon_io/favicon-16x16.png"
            sizes="16x16"
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/favicon_io/apple-touch-icon.png"
        />
        <link rel="manifest" href="/favicon_io/site.webmanifest" />
    </head>
    <body
        class="font-mono flex items-center justify-start flex-col w-screen min-h-screen tracking-tight selection:bg-cyan-100"
    >
        <slot />
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
