    chevron: '<path d="M6 9l6 6 6-6"/>',
};

const fill = fillIcons[name];
const stroke = strokeIcons[name];
---

{
    fill && (
        <svg
            class={className}
            viewBox={fill.viewBox}
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
        >
            <path d={fill.path} />
        </svg>
    )
}
{
    stroke && (
        <svg
            class={className}
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            focusable="false"
            set:html={stroke}
        />
    )
}
