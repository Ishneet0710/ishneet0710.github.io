---
import Icon from "./Icon.astro";

interface Author {
    name: string;
    highlight?: boolean;
    marks?: string;
}
interface VenueLine {
    text: string;
    note?: string;
    variant?: string;
}
interface PubLink {
    kind: "paper" | "code" | "website";
    label: string;
    url: string;
}
interface Props {
    title: string;
    authors: Author[];
    venue: VenueLine[];
    links?: PubLink[];
}
const { title, authors, venue, links = [] } = Astro.props;

const linkIcon: Record<string, string> = {
    paper: "paper",
    code: "github",
    website: "globe",
};
---

<article class="publication-card">
    <div class="publication-card__body">
        <h3 class="publication-card__title">{title}</h3>

        <p class="publication-card__authors">
            {
                authors.map((a, i) => (
                    <>
                        <span
                            class={
                                a.highlight
                                    ? "publication-card__author publication-card__author--self"
                                    : "publication-card__author"
                            }
                        >
                            {a.name}
                            {a.marks && <sup>{a.marks}</sup>}
                        </span>
                        {i !== authors.length - 1 && <span>, </span>}
                    </>
                ))
            }
        </p>

        <div class="publication-card__venues">
            {
                venue.map((v, i) => (
                    <p
                        class={
                            i === 0
                                ? "publication-card__venue-line publication-card__venue-line--primary"
                                : "publication-card__venue-line"
                        }
                    >
                        {v.text}
                        {v.note && (
                            <span
                                class={
                                    v.variant
                                        ? `publication-card__venue-note publication-card__venue-note--${v.variant}`
                                        : "publication-card__venue-note"
                                }
                            >
                                {v.note}
                            </span>
                        )}
                    </p>
                ))
            }
        </div>

        {
            links.length > 0 && (
                <div class="publication-card__links">
                    {links.map((l) => (
                        <a
                            class="publication-chip"
                            href={l.url}
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            <Icon name={linkIcon[l.kind]} class="chip-icon" />
                            <span>{l.label}</span>
                        </a>
                    ))}
                </div>
            )
        }
    </div>
</article>
